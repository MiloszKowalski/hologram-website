---
import Layout from "../layouts/LayoutWithoutScripts.astro";
---

<Layout>
  <main class="flex flex-col h-screen justify-center items-center text-white">
    <div class="flex flex-col gap-16 items-center text-center p-4">
      <h1 class="text-2xl md:text-4xl font-bold">Nie można znaleźć strony</h1>
      <p class="max-w-[35ch] font-[Chivo_Mono] text-md md:text-xl">
        Przepraszamy, żądana strona nie istnieje lub jej link wygasł.
      </p>
    </div>
  </main>
</Layout>
